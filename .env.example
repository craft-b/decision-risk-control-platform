# .env.example — Enterprise Asset Intelligence
# Copy to .env and fill in real values before running docker-compose.
# NEVER commit .env to git. This file is safe to commit.

# ── Database ─────────────────────────────────────────────────────────────────
# Full DSN used by Node/Drizzle. Must match the DB_* vars below.
DATABASE_URL=mysql://user:password@host:3306/enterprise_assets

# Individual vars used by the Python ML service (SQLAlchemy).
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=enterprise_assets

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-64-char-random-hex
JWT_SECRET=replace-with-64-char-random-hex

# ── ML Service ────────────────────────────────────────────────────────────────
MODEL_VERSION=v1

LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-8b-8192

# ── Frontend (optional) ───────────────────────────────────────────────────────
# Leave blank — Nginx proxies /api to the server container automatically.
# Set only if deploying client and server on separate domains.
VITE_API_URL=
